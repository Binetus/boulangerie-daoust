---
import Layout from '../layouts/Layout.astro';
import business from '../data/business.json';

const openHours = business.hours
  .filter(h => h.open)
  .map(h => ({
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": h.dayEn,
    "opens": h.timeOpens,
    "closes": h.timeCloses
  }));

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Bakery",
  "name": business.name,
  "telephone": business.phoneRaw,
  "email": business.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": business.address.street,
    "addressLocality": business.address.city,
    "addressRegion": business.address.region,
    "postalCode": business.address.postalCode,
    "addressCountry": "CA"
  },
  "inLanguage": "fr-CA",
  "openingHoursSpecification": openHours,
  "image": [business.photos.hero, business.photos.storyImage, ...business.photos.gallery],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": business.rating,
    "reviewCount": business.reviewCount
  }
};

const today = new Date().toLocaleDateString("fr-CA", { weekday: "long" });
const todayCapitalized = today.charAt(0).toUpperCase() + today.slice(1);
const todayHours = business.hours.find(h => h.day === todayCapitalized);
---
<Layout title={`${business.name} – ${business.tagline}`}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <header class="hero">
    <img src={business.photos.hero} alt={`Devanture de ${business.name}`} />
    <div class="hero-overlay">
      <p class="tagline">{business.tagline}</p>
      <p class="rating">★ {business.rating} <span>({business.reviewCount} avis Google)</span></p>
    </div>
  </header>
<section class="menu">
  <h2>Notre menu</h2>
  <p class="menu-intro">Produits frais du jour, préparés sur place.</p>
  <div class="menu-boards">
    {business.menu.map(category => (
      <div class="menu-board">
        <h3>{category.category}</h3>
        <ul class="menu-board-list">
          {category.items.map(item => (
            <li class="menu-board-item">
              <span class="name">{item.name}</span>
              <span class="price">{item.price}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>

  <section class="story">
    <h2>Notre histoire</h2>
    <div class="story-content">
      <img src={business.photos.storyImage} alt="Devanture de la Boulange Chez Daoust à Notre-Dame-du-Laus" class="story-image" loading="lazy" />
      <p>{business.history}</p>
    </div>
  </section>

  <section class="wood-oven">
    <h2>Le four à bois, notre signature</h2>
    <div class="wood-oven-grid">
      {business.photos.woodOven.map(src => (
        <img src={src} alt="Notre four à bois d'origine" loading="lazy" />
      ))}
    </div>
    <p>Depuis quatre générations, nous cuisons nos pains au four à bois. Une tradition vivante qui donne à chaque produit un goût fumé, profond, impossible à reproduire dans un four moderne.</p>
  </section>

  <section class="specialties">
    <h2>Nos spécialités</h2>
    <div class="specialty-grid">
      {business.specialties.map(s => (
        <article class="specialty-card">
          <h3>
            <a href={s.image} target="_blank" rel="noopener noreferrer">
              {s.name} <span class="arrow">→</span>
            </a>
          </h3>
          {s.description && <p>{s.description}</p>}
        </article>
      ))}
    </div>
  </section>

  <section class="gallery">
    <h2>En images</h2>
    <div class="gallery-grid">
      {business.photos.gallery.map(src => (
        <img src={src} alt="" loading="lazy" />
      ))}
    </div>
  </section>

  <section class="payments">
    <h2>Modes de paiement acceptés</h2>
    <ul class="payment-list">
      {business.payments.map(p => (
        <li class="payment-item">
          <span class="check">✅</span> {p}
        </li>
      ))}
    </ul>
  </section>

  <section class="hours">
    <h2>Heures d'ouverture</h2>
    <ul class="hours-list">
      {business.hours.map(h => (
        <li class={h.open ? 'open' : 'closed'}>
          <span class="day">{h.day}</span>
          <span class="time">{h.time}</span>
        </li>
      ))}
    </ul>
    {todayHours && (
      <p class="today">
        {todayHours.open
          ? `✅ Aujourd'hui, nous sommes ouverts de ${todayHours.time.toLowerCase()}.`
          : `🚫 Aujourd'hui, nous sommes fermés.`}
      </p>
    )}
  </section>

  <section class="address">
    <h2>Nous trouver</h2>
    <p class="address-line">📍 {business.address.full}</p>
    <p class="phone-line">📞 <a href={`tel:${business.phoneRaw}`}>{business.phone}</a></p>
    <div class="address-buttons">
      <a class="maps-link" href={`https://www.google.com/maps/search/${encodeURIComponent(business.name + ' ' + business.address.full)}`}>Ouvrir dans Google Maps →</a>
      <a class="contact-button" href={`mailto:${business.email}`}>✉️ Nous joindre</a>
    </div>

    <div class="qr-section">
      <h3>📱 Scannez pour ouvrir cette page sur votre téléphone</h3>
      <img
        src={`https://api.qrserver.com/v1/create-qr-code/?data=${encodeURIComponent('https://boulangerie-daoust.pages.dev')}&size=200x200`}
        alt="Code QR du site de la Boulange Chez Daoust"
        class="qr-code"
        loading="lazy"
      />
      <p class="qr-help">À imprimer et coller au comptoir, ou à partager avec vos clients.</p>
    </div>
  </section>

  <footer>
    <p>© {new Date().getFullYear()} {business.name} · {business.address.city}, QC</p>
  </footer>
</Layout>

<style>
  :root {
    --cream: #fdfaf5;
    --card: #fff8ed;
    --text: #2d2419;
    --accent: #b87333;
    --muted: #8b7d6b;
    --border: #e8dfd0;
  }
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    color: var(--text);
    background: var(--cream);
    line-height: 1.65;
  }
  h1, h2, h3 { font-family: Georgia, "Times New Roman", serif; color: var(--text); }
  h1 { font-size: 2.5rem; margin: 0; }
  h2 { font-size: 1.75rem; margin: 0 0 1rem; padding-bottom: 0.5rem; border-bottom: 2px solid var(--accent); }
  h3 { font-size: 1.15rem; margin: 0 0 0.4rem; }
  p { margin: 0.5rem 0; }

  .hero { position: relative; width: 100%; height: 420px; overflow: hidden; }
  .hero img { width: 100%; height: 100%; object-fit: cover; }
.hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to bottom, rgba(255,250,245,0.85), rgba(255,250,245,0));
  display: flex; flex-direction: column;
  justify-content: flex-start;
  align-items: flex-end;
  text-align: right;
  padding: 2rem; color: #2d2419;
}
  .hero-overlay h1 { color: white; margin: 0 0 0.25rem; }
  .hero-overlay .tagline { font-size: 1.15rem; opacity: 0.95; margin: 0 0 0.5rem; }
  .hero-overlay .rating { font-size: 1rem; opacity: 0.9; margin: 0; }
  .hero-overlay .rating span { opacity: 0.75; font-size: 0.9rem; }

  section { padding: 1.75rem 2rem; max-width: 1100px; margin: 0 auto; }
  .story { background: var(--card); border-left: 4px solid var(--accent); }
  .story p { font-size: 1.05rem; line-height: 1.7; }

  .story-content {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 1.5rem;
    align-items: center;
    margin-top: 1rem;
  }
  .story-image {
    width: 100%;
    height: 280px;
    object-fit: cover;
    border-radius: 8px;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.12);
  }

  .wood-ven-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 1rem 0 1.25rem;
  }
  .wood-oven-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 1rem 0 1.25rem;
  }
  .wood-oven-grid img { width: 100%; border-radius: 8px; height: 280px; object-fit: cover; }

  .specialty-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem; margin: 1rem 0;
  }
  .specialty-card {
    background: var(--card); padding: 1.25rem;
    border-radius: 8px; border: 1px solid var(--border);
  }
  .specialty-card h3 a {
    color: var(--text);
    text-decoration: none;
    border-bottom: 2px dotted var(--accent);
    padding-bottom: 2px;
    transition: color 0.15s, border-bottom-style 0.15s;
  }
  .specialty-card h3 a:hover {
    color: var(--accent);
    border-bottom-style: solid;
  }
  .specialty-card h3 a .arrow {
    display: inline-block;
    font-weight: normal;
    transition: transform 0.2s;
  }
  .specialty-card h3 a:hover .arrow { transform: translateX(4px); }
.menu-intro { color: var(--muted); font-style: italic; margin-bottom: 1rem; }

.menu-boards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  margin: 1rem 0;
}

.menu-board {
  background: #1a1410;
  color: #f5f0e8;
  padding: 1.5rem 1.25rem;
  border-radius: 8px;
  border: 1px solid #2a2018;
  box-shadow:
    inset 0 0 30px rgba(0,0,0,0.5),
    0 4px 14px rgba(0,0,0,0.25);
  position: relative;
}

.menu-board h3 {
  text-align: center;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  font-size: 1.2rem;
  margin: 0 0 1.25rem;
  padding-bottom: 0.6rem;
  border-bottom: 1px dashed rgba(245, 240, 232, 0.3);
  color: #f5f0e8;
  font-family: Georgia, "Times New Roman", serif;
}

.menu-board-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.menu-board-item {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 0.45rem 0;
  border-bottom: 1px dotted rgba(245, 240, 232, 0.18);
  font-size: 0.98rem;
}

.menu-board-item:last-child {
  border-bottom: none;
}

.menu-board-item .name { 
  flex: 1; 
  padding-right: 0.5rem;
}

.menu-board-item .price { 
  margin-left: 1rem;
  white-space: nowrap;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  color: #b87333;
}

  .menu-grid img {
    width: 100%;
    height: 280px;
    object-fit: cover;
    border-radius: 8px;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.1);
  }

  .gallery-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.75rem; margin: 1rem 0;
  }
  .gallery-grid img { width: 100%; height: 200px; object-fit: cover; border-radius: 6px; }

  .payment-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0;
    display: grid;
    gap: 0.5rem;
    max-width: 480px;
  }
  .payment-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.9rem;
    background: var(--card);
    border-radius: 6px;
    border: 1px solid var(--border);
    font-size: 1.05rem;
  }
  .check { font-size: 1.2rem; }

  .hours-list { list-style: none; padding: 0; margin: 1rem 0; max-width: 360px; }
  .hours-list li {
    display: flex; justify-content: space-between;
    padding: 0.6rem 0.9rem; border-bottom: 1px solid var(--border);
  }
  .hours-list li.closed { color: var(--muted); font-style: italic; }
  .hours-list .day { font-weight: 600; }
  .today {
    background: var(--card); padding: 0.75rem 1rem; border-radius: 6px;
    border-left: 3px solid var(--accent); font-weight: 500; margin-top: 1rem;
  }

  .address-line, .phone-line { font-size: 1.1rem; }
  .address-buttons {
    display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1rem;
  }
  .maps-link, .contact-button {
    display: inline-block; padding: 0.75rem 1.25rem; border-radius: 6px;
    text-decoration: none; font-weight: 500; color: white; background: var(--accent);
  }
  .maps-link:hover, .contact-button:hover { background: #9a5d2a; }
  .contact-button { background: var(--text); }
  .contact-button:hover { background: #1a1410; }

  .qr-section {
    margin-top: 2rem;
    padding: 1.5rem;
    background: var(--card);
    border-radius: 8px;
    border: 1px solid var(--border);
    text-align: center;
    max-width: 320px;
  }
  .qr-section h3 {
    font-size: 1.05rem;
    margin: 0 0 1rem;
    border: none;
    padding: 0;
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, sans-serif;
  }
  .qr-code {
    width: 200px; height: 200px; margin: 0 auto; display: block; border-radius: 4px;
  }
  .qr-help {
    font-size: 0.85rem; color: var(--muted); margin-top: 0.75rem;
  }

  footer {
    text-align: center; padding: 2rem 1rem; color: var(--muted);
    font-size: 0.9rem; border-top: 1px solid var(--border); margin-top: 2rem;
  }

  @media (max-width: 700px) {
    .story-content { grid-template-columns: 1fr; }
    .story-image { height: 220px; order: -1; }
    .wood-oven-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .hero { height: 280px; }
    h1 { font-size: 1.85rem; }
    h2 { font-size: 1.45rem; }
    section { padding: 1rem; }
    .address-buttons { flex-direction: column; align-items: flex-start; }
    .menu-boards { grid-template-columns: 1fr; }
  }
</style>

