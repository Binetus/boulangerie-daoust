---
import Layout from '../layouts/Layout.astro';
import business from '../data/business.json';

const openHours = business.hours
  .filter(h => h.open)
  .map(h => ({
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": h.dayEn,
    "opens": h.timeOpens,
    "closes": h.timeCloses
  }));

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Bakery",
  "name": business.name,
  "telephone": business.phoneRaw,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": business.address.street,
    "addressLocality": business.address.city,
    "addressRegion": business.address.region,
    "postalCode": business.address.postalCode,
    "addressCountry": "CA"
  },
  "inLanguage": "fr-CA",
  "openingHoursSpecification": openHours,
  "image": [business.photos.hero, business.photos.storyImage, ...business.photos.gallery],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": business.rating,
    "reviewCount": business.reviewCount
  }
};

const today = new Date().toLocaleDateString("fr-CA", { weekday: "long" });
const todayCapitalized = today.charAt(0).toUpperCase() + today.slice(1);
const todayHours = business.hours.find(h => h.day === todayCapitalized);
---
<Layout title={`${business.name} – ${business.tagline}`}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <header class="hero">
    <img src={business.photos.hero} alt={`Devanture de ${business.name}`} />
    <div class="hero-overlay">
      <p class="tagline">{business.tagline}</p>
      <p class="rating">★ {business.rating} <span>({business.reviewCount} avis Google)</span></p>
    </div>
  </header>

  <section class="story">
    <h2>Notre histoire</h2>
    <div class="story-content">
      <img
        src={business.photos.storyImage}
        alt="Devanture de la Boulange Chez Daoust à Notre-Dame-du-Laus"
        class="story-image"
        loading="lazy"
      />
      <p>{business.history}</p>
    </div>
  </section>

  <section class="wood-oven">
    <h2>Le four à bois, notre signature</h2>
    <div class="wood-oven-grid">
      {business.photos.woodOven.map(src => (
        <img src={src} alt="Notre four à bois d'origine" loading="lazy" />
      ))}
    </div>
    <p>Depuis quatre générations, nous cuisons nos pains au four à bois. Une tradition vivante qui donne à chaque produit un goût incomparable, profond, impossible à reproduire dans un four moderne.</p>
  </section>

  <section class="specialties">
    <h2>Nos spécialités</h2>
    <div class="specialty-grid">
      {business.specialties.map(s => (
        <article class="specialty-card">
          <h3>{s.name}</h3>
          {s.description && <p>{s.description}</p>}
        </article>
      ))}
    </div>
  </section>

  <section class="menu">
    <h2>Notre menu</h2>
    <p class="menu-intro">Produits frais du jour, préparés sur place.</p>
    <div class="menu-boards">
      {business.menu.map(category => (
        <div class="menu-board">
          <h3>{category.category}</h3>
          <ul class="menu-board-list">
            {category.items.map(item => (
              <li class="menu-board-item">
                <span class="name">{item.name}</span>
                <span class="price">{item.price}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="gallery">
    <h2>En images</h2>
    <div class="carousel">
      <button class="carousel-arrow carousel-arrow-left" aria-label="Photo précédente">‹</button>
      <div class="carousel-track" id="carousel-track">
        {business.photos.gallery.map((src, i) => (
          <div class="carousel-slide" data-caption={business.photos.galleryCaptions?.[i] || ''}>
            <img src={src} alt={business.photos.galleryCaptions?.[i] || `Photo de la boulangerie ${i + 1}`} loading="lazy" />
          </div>
        ))}
      </div>
      <button class="carousel-arrow carousel-arrow-right" aria-label="Photo suivante">›</button>
    </div>
    <p class="carousel-active-caption" id="carousel-active-caption">
      {business.photos.galleryCaptions?.[0] || ''}
    </p>
  </section>

  <section class="payments">
    <h2>Modes de paiement acceptés</h2>
    <ul class="payment-list">
      {business.payments.map(p => (
        <li class="payment-item">
          <span class="check">✅</span> {p}
        </li>
      ))}
    </ul>
  </section>

  <section class="hours">
    <h2>Heures d'ouverture</h2>
    <ul class="hours-list">
      {business.hours.map(h => (
        <li class={h.open ? 'open' : 'closed'}>
          <span class="day">{h.day}</span>
          <span class="time">{h.time}</span>
        </li>
      ))}
    </ul>
    {todayHours && (
      <p class="today">
        {todayHours.open
          ? `✅ Aujourd'hui, nous sommes ouverts de ${todayHours.time.toLowerCase()}.`
          : `🚫 Aujourd'hui, nous sommes fermés.`}
      </p>
    )}
  </section>

  <section class="address">
    <h2>Nous trouver</h2>
    <p class="address-line">📍 {business.address.full}</p>

    <div class="phone-and-contact">
      <p class="phone-line">📞 <a href={`tel:${business.phoneRaw}`}>{business.phone}</a></p>
      <a class="contact-button inline" href={`mailto:${business.email}`}>✉️ Nous joindre</a>
    </div>

    <div class="address-buttons">
      <a class="maps-link"
         href={`https://www.google.com/maps/search/${encodeURIComponent(business.name + ' ' + business.address.full)}`}
         target="_blank"
         rel="noopener noreferrer">
        Ouvrir dans Google Maps →
      </a>

      <a class="review-qr-wrapper"
         href="https://search.google.com/local/writereview?placeid=ChIJ-9ilfecl0EwRwb8reNou_sc"
         target="_blank"
         rel="noopener noreferrer"
         aria-label="Laisser un avis Google">
        <img
          src="https://api.qrserver.com/v1/create-qr-code/?data=https%3A%2F%2Fsearch.google.com%2Flocal%2Fwritereview%3Fplaceid%3DChIJ-9ilfecl0EwRwb8reNou_sc&size=150x150"
          alt="Code QR pour laisser un avis Google"
          class="qr-review"
        />
        <span class="qr-review-label">⭐ Laisser un avis</span>
      </a>
    </div>

    <a class="facebook-link"
       href="https://www.facebook.com/profile.php?id=61567956039360"
       target="_blank"
       rel="noopener noreferrer">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
        <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
      </svg>
      Suivez-nous sur Facebook
    </a>

    <div class="qr-section">
      <h3>📱 Scannez pour ouvrir cette page sur votre téléphone</h3>
      <img
        src={`https://api.qrserver.com/v1/create-qr-code/?data=${encodeURIComponent('https://boulangechezdaoust.pages.dev/')}&size=200x200`}
        alt="Code QR du site de la Boulange Chez Daoust"
        class="qr-code"
        loading="lazy"
      />
      <p class="qr-help">Scannez pour ouvrir le site sur votre téléphone</p>

      <div class="qr-download">
        <a href="/qr/qr-site-web.png" download="QR-Site-Boulange.png">📥 Télécharger le QR du site</a>
        <a href="/qr/qr-google-avis.png" download="QR-Avis-Google.png">📥 Télécharger le QR (laisser un avis)</a>
      </div>
    </div>
  </section>

  <footer>
    <p>© {new Date().getFullYear()} {business.name} · {business.address.city}, QC</p>
    <p class="credit">
      Conception et réalisation par <strong>Binetus média</strong>
      <a href="mailto:binette.michel.qc@gmail.com" class="credit-mail" aria-label="Contacter Binetus média">
        ✉️
      </a>
    </p>
  </footer>
</Layout>

<script>
  const track = document.getElementById('carousel-track');
  if (track) {
    const slides = Array.from(track.querySelectorAll('.carousel-slide'));
    const caption = document.getElementById('carousel-active-caption');
    const arrows = document.querySelectorAll('.carousel-arrow');

    const updateActive = () => {
      const trackCenter = track.scrollLeft + track.offsetWidth / 2;
      let closestSlide = slides[0];
      let minDist = Infinity;
      slides.forEach(slide => {
        const slideCenter = slide.offsetLeft + slide.offsetWidth / 2;
        const dist = Math.abs(slideCenter - trackCenter);
        if (dist < minDist) { closestSlide = slide; minDist = dist; }
      });
      slides.forEach(s => s.classList.remove('is-active'));
      closestSlide.classList.add('is-active');
      if (caption && closestSlide.dataset.caption) {
        caption.textContent = closestSlide.dataset.caption;
      }
    };

    arrows.forEach(arrow => {
      arrow.addEventListener('click', () => {
        const slideWidth = slides[0].offsetWidth;
        const gap = 16;
        const dir = arrow.classList.contains('carousel-arrow-left') ? -1 : 1;
        track.scrollBy({ left: dir * (slideWidth + gap), behavior: 'smooth' });
      });
    });

    track.addEventListener('scroll', updateActive, { passive: true });
    updateActive();
  }
</script>

<style>
  :root {
    --cream: #080400;
    --card: #2a2018;
    --text: #f5f0e8;
    --accent: #d68c4a;
    --muted: #a09184;
    --border: #050202;
  }

  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    color: var(--text);
    background: var(--cream);
    line-height: 1.65;
  }

  h1, h2, h3 {
    font-family: Georgia, "Times New Roman", serif;
    color: var(--text);
  }
  h2 {
    font-size: 1.75rem;
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--accent);
  }
  h3 { font-size: 1.15rem; margin: 0 0 0.4rem; }
  p { margin: 0.5rem 0; }

  section {
    padding: 1.75rem 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ==================== HERO ==================== */
  .hero {
    position: relative;
    width: 100%;
    height: 600px;
    overflow: hidden;
  }
  .hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 50%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: transparent;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-end;
    text-align: right;
    padding: 2rem;
  }
  .hero-overlay .tagline,
  .hero-overlay .rating {
    color: #1a1410;
    text-shadow:
      0 0 8px rgba(255, 250, 240, 0.9),
      0 0 4px rgba(255, 250, 240, 0.7),
      0 1px 2px rgba(0, 0, 0, 0.3);
  }
  .hero-overlay .tagline { font-size: 1.15rem; opacity: 0.95; margin: 0 0 0.5rem; }
  .hero-overlay .rating { font-size: 1rem; opacity: 0.9; margin: 0; }
  .hero-overlay .rating span { opacity: 0.75; font-size: 0.9rem; }

  /* ==================== STORY ==================== */
  .story {
    background: var(--card);
    border-left: 4px solid var(--accent);
  }
  .story p { font-size: 1.05rem; line-height: 1.7; }

  .story-content {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 1.5rem;
    align-items: center;
    margin-top: 1rem;
  }
  .story-image {
    width: 100%;
    height: 400px;
    object-fit: cover;
    border-radius: 8px;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.12);
  }

  /* ==================== WOOD OVEN ==================== */
  .wood-oven-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 1rem 0 1.25rem;
  }
  .wood-oven-grid img {
    width: 100%;
    border-radius: 8px;
    height: 280px;
    object-fit: cover;
  }

  /* ==================== SPECIALTIES ==================== */
  .specialty-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    margin: 1rem 0;
  }
  .specialty-card {
    background: var(--card);
    padding: 1.25rem;
    border-radius: 8px;
    border: 1px solid var(--border);
  }

  /* ==================== MENU ==================== */
  .menu-intro {
    color: var(--muted);
    font-style: italic;
    margin-bottom: 1rem;
  }

  .menu-boards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin: 1rem 0;
  }

  .menu-board {
    background: #1a1410;
    color: #f5f0e8;
    padding: 1.5rem 1.25rem;
    border-radius: 8px;
    border: 1px solid #2a2018;
    box-shadow:
      inset 0 0 30px rgba(0, 0, 0, 0.5),
      0 4px 14px rgba(0, 0, 0, 0.25);
    position: relative;
  }
  .menu-board h3 {
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 1.2rem;
    margin: 0 0 1.25rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px dashed rgba(245, 240, 232, 0.3);
    color: #f5f0e8;
  }
  .menu-board-list { list-style: none; padding: 0; margin: 0; }
  .menu-board-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.45rem 0;
    border-bottom: 1px dotted rgba(245, 240, 232, 0.18);
    font-size: 0.98rem;
  }
  .menu-board-item:last-child { border-bottom: none; }
  .menu-board-item .name { flex: 1; padding-right: 0.5rem; }
  .menu-board-item .price {
    margin-left: 1rem;
    white-space: nowrap;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    color: #b87333;
  }

  /* ==================== CAROUSEL ==================== */
  .carousel { position: relative; margin: 1rem 0; }

  .carousel-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    gap: 1rem;
    padding: 1rem 0;
    scrollbar-width: thin;
    scrollbar-color: var(--accent) transparent;
  }
  .carousel-track::before,
  .carousel-track::after {
    content: '';
    flex: 0 0 calc((100% - 2rem) / 6);
  }
  .carousel-track::-webkit-scrollbar { height: 6px; }
  .carousel-track::-webkit-scrollbar-thumb {
    background: var(--accent);
    border-radius: 3px;
  }

  .carousel-slide {
    flex: 0 0 calc((100% - 2rem) / 3);
    scroll-snap-align: center;
    border-radius: 8px;
    overflow: hidden;
    aspect-ratio: 4/3;
    position: relative;
    opacity: 0.2;
    filter: blur(1px);
    transform: scale(0.95);
    transition: opacity 0.4s ease, filter 0.4s ease, transform 0.4s ease;
  }
  .carousel-slide.is-active {
    opacity: 1;
    filter: blur(0);
    transform: scale(1);
  }
  .carousel-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .carousel-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(184, 115, 51, 0.9);
    color: white;
    border: none;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    font-size: 1.6rem;
    line-height: 1;
    cursor: pointer;
    z-index: 5;
    font-weight: bold;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, transform 0.2s;
  }
  .carousel-arrow-left  { left: 0.5rem; }
  .carousel-arrow-right { right: 0.5rem; }
  .carousel-arrow:hover {
    background: var(--accent);
    transform: translateY(-50%) scale(1.1);
  }

  .carousel-active-caption {
    text-align: center;
    margin: 1.5rem auto 0;
    max-width: 600px;
    font-style: italic;
    color: var(--text);
    font-size: 1.05rem;
    opacity: 0.85;
    min-height: 1.5em;
  }

  /* ==================== PAYMENTS ==================== */
  .payment-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0;
    display: grid;
    gap: 0.5rem;
    max-width: 480px;
  }
  .payment-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.9rem;
    background: var(--card);
    border-radius: 6px;
    border: 1px solid var(--border);
    font-size: 1.05rem;
  }
  .check { font-size: 1.2rem; }

  /* ==================== HOURS ==================== */
  .hours-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0;
    max-width: 360px;
  }
  .hours-list li {
    display: flex;
    justify-content: space-between;
    padding: 0.6rem 0.9rem;
    border-bottom: 1px solid var(--border);
  }
  .hours-list li.closed {
    color: var(--muted);
    font-style: italic;
  }
  .hours-list .day { font-weight: 600; }
  .today {
    background: var(--card);
    padding: 0.75rem 1rem;
    border-radius: 6px;
    border-left: 3px solid var(--accent);
    font-weight: 500;
    margin-top: 1rem;
  }

  /* ==================== ADDRESS ==================== */
  .address-line, .phone-line { font-size: 1.1rem; }

  .phone-and-contact {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }
  .phone-and-contact .contact-button.inline {
    background-color: #b87333 !important;
    color: white !important;
    margin: 0;
    padding: 0.6rem 1rem;
    font-size: 0.95rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 500;
    transition: background 0.2s;
  }
  .phone-and-contact .contact-button.inline:hover {
    background-color: #8b5e29 !important;
  }

  .address-buttons {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 2.5rem;
    margin-top: 1.5rem;
  }

  .maps-link {
    display: inline-block;
    background: #b87333;
    color: white !important;
    padding: 0.75rem 1.25rem;
    border-radius: 6px;
    text-decoration: none !important;
    font-weight: 500;
    border: 2px solid transparent;
    transition: background 0.2s, transform 0.2s;
  }
  .maps-link:hover {
    background: #8b5e29;
    transform: translateY(-1px);
  }

  .review-qr-wrapper {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    background: var(--card);
    padding: 0.6rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    transition: transform 0.15s, border-color 0.15s;
  }
  .review-qr-wrapper:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
  }
  .qr-review {
    width: 80px;
    height: 80px;
    display: block;
    border-radius: 4px;
  }
  .qr-review-label {
    font-size: 0.75rem;
    color: var(--muted);
    margin-top: 0.4rem;
    font-weight: 500;
    text-align: center;
  }

  .facebook-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: #1877f2;
    color: white !important;
    padding: 0.75rem 1.25rem;
    border-radius: 6px;
    text-decoration: none !important;
    font-weight: 500;
    margin-top: 1.5rem;
    transition: background 0.2s, transform 0.2s;
  }
  .facebook-link:hover {
    background: #0d65d9;
    transform: translateY(-1px);
  }
  .facebook-link svg { flex-shrink: 0; }

  .qr-section {
    margin-top: 2rem;
    padding: 1.5rem;
    background: var(--card);
    border-radius: 8px;
    border: 1px solid var(--border);
    text-align: center;
    max-width: 320px;
  }
  .qr-section h3 {
    font-size: 1.05rem;
    margin: 0 0 1rem;
    border: none;
    padding: 0;
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, sans-serif;
  }
  .qr-code {
    width: 200px;
    height: 200px;
    margin: 0 auto;
    display: block;
    border-radius: 4px;
  }
  .qr-help {
    font-size: 0.85rem;
    color: var(--muted);
    margin-top: 0.75rem;
  }
  .qr-download {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: 1.5rem;
  }
  .qr-download a {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: #b87333 !important;
    color: white !important;
    text-decoration: none !important;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 500;
    text-align: center;
    transition: background 0.2s;
  }
  .qr-download a:hover {
    background: #8b5e29 !important;
  }

  /* ==================== FOOTER ==================== */
  footer {
    text-align: center;
    padding: 2rem 1rem;
    color: var(--muted);
    font-size: 0.9rem;
    border-top: 1px solid var(--border);
    margin-top: 2rem;
  }
  footer p {
    display: block;
    width: 100%;
    margin: 0.5rem 0;
    text-align: center;
  }
  footer .credit {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    opacity: 0.75;
    letter-spacing: 0.02em;
  }
  footer .credit strong {
    color: var(--accent);
  }
  footer .credit-mail {
    display: inline-block;
    margin-left: 0.5rem;
    color: var(--accent);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.2s, transform 0.2s;
  }
  footer .credit-mail:hover {
    color: #e8a868;
    transform: scale(1.2);
  }

