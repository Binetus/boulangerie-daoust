---
interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = "Boulangerie artisanale au four à bois à Notre-Dame-du-Laus, dans les Laurentides. Pains, beignes, galettes à la mélasse et pizza cuits au feu de bois. Quatre générations de tradition familiale depuis 1948."
} = Astro.props;
---
<!doctype html>
<html lang="fr-CA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#b87333" />
    <meta name="description" content={description} />
    <meta name="format-detection" content="telephone=no" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_CA" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">Aller au contenu principal</a>
    <main id="main">
      <slot />
    </main>

    <style is:global>
      :focus-visible {
        outline: 3px solid #b87333;
        outline-offset: 3px;
        border-radius: 4px;
      }

      html {
        scroll-behavior: smooth;
      }

      .skip-link {
        position: absolute;
        left: 0.5rem;
        top: -3.5rem;
        z-index: 100;
        padding: 0.75rem 1.1rem;
        background: #b87333;
        color: #ffffff;
        font-weight: 600;
        font-size: 0.95rem;
        text-decoration: none;
        border-radius: 0 0 6px 6px;
        transition: top 0.2s ease;
      }

      .skip-link:focus,
      .skip-link:focus-visible {
        top: 0;
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
        *,
        *::before,
        *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
        }
      }
    </style>
  </body>
</html>
