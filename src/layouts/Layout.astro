---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="fr-CA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Boulangerie artisanale au four à bois, Notre-Dame-du-Laus, Laurentides. Pains, beignes, galettes à la mélasse et pizza cuits au feu de bois." />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
